---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildWorldTree } from '../lib/build-tree';
import World from '../components/World';

const entries = await getCollection('notes');
const tree = buildWorldTree(entries);
---
<BaseLayout>
  <main class="world-main">
    <World tree={tree} client:only="react" />
    <noscript>
      <div class="no-js">
        This world is rendered in 3D and needs JavaScript. Please enable it
        — or wander into <a href="/notes/travel/kyoto-rain">a note</a> directly.
      </div>
    </noscript>
  </main>
</BaseLayout>
